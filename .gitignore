# npx skills (npx skills add <repo> --skill <name>)
# .agents/skills/ is the npx-managed install dir, regenerated by `npx skills add`.
# skills-lock.json tracks install state, also regenerated.
# Bundled skills live in ./skills/ and ARE committed (see that dir).
.agents/
skills-lock.json

# OpenCode project-local runtime state (DBs, sessions, package cache)
# Source of truth for agent definitions lives in ./agents/ at project root.
.opencode/

# Husky v9 internal files (generated by `husky` on install)
.husky/_/
