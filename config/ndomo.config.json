{
  "$schema": "./ndomo.schema.json",
  "plugins": [
    "ndomo",
    "opencode-mem"
  ],
  "optionalPlugins": [
    "@tarquinen/opencode-dcp"
  ],
  "agentRouting": {
    "foreman": {
      "description": "Master orchestrator and scheduler",
      "mode": "primary",
      "delegates_to": [
        "scout",
        "scribe",
        "painter",
        "smith",
        "sage",
        "guild",
        "go-smith",
        "js-smith",
        "python-smith",
        "vue-smith",
        "zig-smith",
        "rust-smith",
        "chronicler",
        "inspector"
      ]
    }
  },
  "protectedTools": [
    "memory",
    "compress",
    "task",
    "todowrite",
    "skill"
  ],
  "caveman": {
    "intensity": "full",
    "autoClarity": true
  },
  "presets": {
    "default": {
      "foreman": {
        "model": "minimax/MiniMax-M3",
        "temperature": 0.3,
        "reasoning_effort": "high"
      },
      "scout": {
        "model": "opencode/mimo-v2.5-free",
        "temperature": 0.3
      },
      "scribe": {
        "model": "opencode/mimo-v2.5-free",
        "temperature": 0.3
      },
      "painter": {
        "model": "opencode-go/qwen3.7-plus",
        "temperature": 0.2,
        "reasoning_effort": "high"
      },
      "smith": {
        "model": "opencode-go/deepseek-v4-flash",
        "temperature": 0.1,
        "reasoning_effort": "high"
      },
      "sage": {
        "model": "opencode-go/kimi-k2.7-code",
        "temperature": 0.2,
        "reasoning_effort": "high"
      },
      "guild": {
